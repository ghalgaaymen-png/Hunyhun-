<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hentai Vault • hentai123</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { background: #0a0a0a; font-family: 'Segoe UI', sans-serif; }
    .neon-pink { text-shadow: 0 0 20px #ff00aa, 0 0 40px #ff00aa; }
    .card-hover { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .card-hover:hover { transform: scale(1.08) rotate(1deg); box-shadow: 0 0 30px #ff00aa; }
    .modal { animation: popIn 0.3s ease; }
    @keyframes popIn { from { opacity: 0; transform: scale(0.7); } to { opacity: 1; transform: scale(1); } }
  </style>
</head>
<body class="text-white min-h-screen">

  <!-- شاشة الكلمة السرية -->
  <div id="passwordScreen" class="fixed inset-0 bg-black flex items-center justify-center z-50">
    <div class="text-center">
      <h1 class="text-6xl font-bold neon-pink mb-8 tracking-widest">HENTAI VAULT</h1>
      <p class="text-pink-400 text-xl mb-6">أدخل الكود السري...</p>
      <input id="passwordInput" type="password" placeholder="hentai123" 
             class="bg-zinc-900 border border-pink-500 text-white px-8 py-4 text-2xl rounded-xl focus:outline-none focus:border-pink-400 w-80 text-center">
      <button onclick="checkPassword()" 
              class="mt-6 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 px-12 py-4 rounded-2xl text-xl font-bold transition">
        افتح البوابة 🔥
      </button>
      <p id="errorMsg" class="text-red-500 mt-4 hidden">الكود غلط... جرب مرة ثانية</p>
    </div>
  </div>

  <!-- التطبيق الرئيسي -->
  <div id="mainApp" class="hidden min-h-screen bg-zinc-950">
    <!-- الهيدر -->
    <header class="bg-black border-b border-pink-500 p-4 flex items-center justify-between sticky top-0 z-40">
      <h1 class="text-3xl font-bold neon-pink">HENTAI VAULT</h1>
      <div class="flex gap-4">
        <input id="searchInput" placeholder="ابحث عن تاج أو اسم..." 
               class="bg-zinc-900 border border-purple-500 rounded-2xl px-6 py-3 w-80 focus:outline-none">
        <button onclick="addNewImage()" class="bg-purple-600 hover:bg-purple-500 px-6 rounded-2xl flex items-center gap-2">
          <i class="fas fa-plus"></i> أضف صورة
        </button>
        <button onclick="randomImage()" class="bg-pink-600 hover:bg-pink-500 px-6 rounded-2xl">عشوائي 🎲</button>
      </div>
    </header>

    <!-- معرض الصور -->
    <div class="p-8">
      <div id="gallery" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6"></div>
    </div>
  </div>

  <!-- نافذة التكبير -->
  <div id="modal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center z-50 p-4" onclick="if(event.target===this) closeModal()">
    <div class="modal bg-zinc-900 max-w-5xl w-full rounded-3xl overflow-hidden">
      <div class="relative">
        <img id="modalImage" class="w-full max-h-[85vh] object-contain" alt="">
        <div class="absolute top-4 right-4 flex gap-3">
          <button onclick="downloadCurrent()" class="bg-black/70 hover:bg-black p-3 rounded-2xl"><i class="fas fa-download"></i></button>
          <button onclick="closeModal()" class="bg-black/70 hover:bg-black p-3 rounded-2xl"><i class="fas fa-times"></i></button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let images = []; // ضع روابط صورك هنا أو استخدم زر "أضف صورة"
    let currentIndex = 0;
    let favorites = JSON.parse(localStorage.getItem('hentaiFavs') || '[]');

    // مثال: أضف روابطك هنا (استبدلها بروابطك من imgur أو catbox)
    // images = ["https://i.imgur.com/XXXX.jpg", "https://i.imgur.com/YYYY.jpg"];

    function checkPassword() {
      const pass = document.getElementById('passwordInput').value;
      if (pass === "hentai123") {
        document.getElementById('passwordScreen').classList.add('hidden');
        document.getElementById('mainApp').classList.remove('hidden');
        loadGallery();
      } else {
        document.getElementById('errorMsg').classList.remove('hidden');
        setTimeout(() => document.getElementById('errorMsg').classList.add('hidden'), 2000);
      }
    }

    function loadGallery() {
      const gallery = document.getElementById('gallery');
      gallery.innerHTML = '';
      images.forEach((img, index) => {
        const div = document.createElement('div');
        div.className = `relative overflow-hidden rounded-3xl card-hover cursor-pointer group`;
        div.innerHTML = `
          <img src="${img}" class="w-full h-80 object-cover">
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 p-4 opacity-0 group-hover:opacity-100 transition">
            <button onclick="toggleFav(${index}); event.stopImmediatePropagation()" class="text-2xl ${favorites.includes(index) ? 'text-red-500' : 'text-white'}">
              ❤️
            </button>
          </div>
        `;
        div.onclick = () => openModal(index);
        gallery.appendChild(div);
      });
    }

    function openModal(index) {
      currentIndex = index;
      document.getElementById('modal').classList.remove('hidden');
      document.getElementById('modalImage').src = images[index];
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
    }

    function toggleFav(index) {
      if (favorites.includes(index)) {
        favorites = favorites.filter(i => i !== index);
      } else {
        favorites.push(index);
      }
      localStorage.setItem('hentaiFavs', JSON.stringify(favorites));
      loadGallery();
    }

    function addNewImage() {
      const url = prompt("ضع رابط الصورة (مثل imgur أو catbox):");
      if (url) {
        images.unshift(url);
        loadGallery();
      }
    }

    function downloadCurrent() {
      const a = document.createElement('a');
      a.href = images[currentIndex];
      a.download = `hentai_${currentIndex}.jpg`;
      a.click();
    }

    function randomImage() {
      if (images.length === 0) return alert("ما في صور بعد!");
      const rand = Math.floor(Math.random() * images.length);
      openModal(rand);
    }

    // فلتر البحث
    document.getElementById('searchInput').addEventListener('input', (e) => {
      // للبساطة: لو تبغى فلتر متقدم أقدر أعدل الكود
      console.log("بحث:", e.target.value);
    });

    // اضغط Enter في حقل الكلمة السرية
    document.getElementById('passwordInput').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') checkPassword();
    });
  </script>
</body>
</html>
